"""
DH-HCRC: Dynamic Heterophilic Hypergraph Community Discovery
for Multi-Agent Resource Coordination.

Reference: Section III (Methodology) of the paper.
"""

import numpy as np
from dataclasses import dataclass, field
from typing import List, Dict, Tuple, Optional


# =====================================================================
# 数据结构定义 (Data Structures)
# =====================================================================

@dataclass
class Agent:
    """智能体节点 v_i, 见公式 (1)"""
    idx: int
    c: np.ndarray           # 能力向量 c_i
    s: np.ndarray           # 操作状态 s_i (位置、速度、剩余能量等)
    a: np.ndarray           # 历史与可靠性 a_i
    d_res: np.ndarray       # 各类资源需求 d_i^nu, 维度 = |T_R|


@dataclass
class Task:
    """任务 m_k, 见公式 (3)"""
    idx: int
    r: np.ndarray           # 能力需求 r_k
    l: np.ndarray           # 位置 l_k
    tau: Tuple[float, float]  # 时间窗 [t_k^s, t_k^e]
    rho: np.ndarray         # 资源需求 rho_k
    pi: float               # 任务优先级 pi_k ∈ [0,1]


@dataclass
class Hyperedge:
    """超边 e, 见公式 (5)-(6)"""
    nodes: List[int]        # 包含的节点索引
    w: float                # 权重 (合作为正, 竞争/冲突为负)
    type: str               # 'tsk' | 'com' | 'res' | 'cfl'
    res_type: Optional[str] = None  # 资源型超边时的资源类别


@dataclass
class Hypergraph:
    """动态异配超图 H(t), 见公式 (5)"""
    V: List[Agent]
    E: List[Hyperedge] = field(default_factory=list)

    @property
    def N(self) -> int:
        return len(self.V)

    @property
    def num_edges(self) -> int:
        return len(self.E)

    def incidence_matrix(self) -> np.ndarray:
        """构建关联矩阵 H, 见公式 (5)"""
        H = np.zeros((self.N, self.num_edges))
        for e_idx, e in enumerate(self.E):
            for v in e.nodes:
                H[v, e_idx] = 1.0
        return H

    def weights(self) -> np.ndarray:
        return np.array([e.w for e in self.E])

    def degree_matrices(self) -> Tuple[np.ndarray, np.ndarray]:
        """节点度与超边度, 见公式 (17)"""
        H = self.incidence_matrix()
        w_abs = np.abs(self.weights())
        Dv = np.diag(H @ w_abs + 1e-12)
        De = np.diag([len(e.nodes) for e in self.E]) if self.E else np.zeros((0, 0))
        return Dv, De


# =====================================================================
# 工具函数 (Utility Functions)
# =====================================================================

def l2_normalize(x: np.ndarray, eps: float = 1e-8) -> np.ndarray:
    """L2 归一化, 见公式 (2)"""
    return x / (np.linalg.norm(x) + eps)


def project_membership(Z: np.ndarray, R_max: int = 3,
                       S_min: int = 1, S_max: int = 50) -> np.ndarray:
    """将隶属矩阵投影到可行集 S_Z, 见公式 (18)"""
    Z = np.clip(Z, 0.0, 1.0)
    # 行约束: 每个节点最多加入 R_max 个社区
    for i in range(Z.shape[0]):
        row_sum = Z[i].sum()
        if row_sum > R_max:
            Z[i] *= R_max / (row_sum + 1e-12)
    # 列约束: 社区规模在 [S_min, S_max]
    for l in range(Z.shape[1]):
        col_sum = Z[:, l].sum()
        if col_sum > S_max:
            Z[:, l] *= S_max / (col_sum + 1e-12)
    return Z


def chi_coverage(Z: np.ndarray, edge_nodes: List[int], l: int,
                 eps: float = 1e-8) -> float:
    """超边-社区覆盖度 (几何均值), 见公式 (19)"""
    vals = Z[edge_nodes, l] + eps
    return float(np.exp(np.mean(np.log(vals))))


# =====================================================================
# 超图构造 (Hypergraph Construction)
# =====================================================================

class HypergraphBuilder:
    """根据任务、通信、资源、冲突关系生成超边, 见公式 (5)-(16)"""

    def __init__(self,
                 theta_rel: float = 0.7,
                 theta_cfl: float = 0.3,
                 kappa_res: float = 1.0,
                 kappa_cfl: float = 1.0,
                 omega: Tuple[float, float, float] = (0.4, 0.3, 0.3)):
        self.theta_rel = theta_rel
        self.theta_cfl = theta_cfl
        self.kappa_res = kappa_res
        self.kappa_cfl = kappa_cfl
        self.omega = omega  # (omega_1, omega_2, omega_3) for Omega_e

    # ---- 任务超边 ----
    def build_task_edges(self, agents: List[Agent], tasks: List[Task],
                         eta: np.ndarray, candidates: List[List[int]]) -> List[Hyperedge]:
        """生成任务型超边, 见公式 (7)-(10)"""
        edges = []
        for k, task in enumerate(tasks):
            for cand in candidates:
                # 累计能力供给
                supply = np.zeros_like(task.r)
                for i in cand:
                    supply += eta[i, k] * l2_normalize(agents[i].c)
                if np.all(supply >= task.r - 1e-6):
                    # 任务匹配分数, 公式 (9)
                    deficit = np.maximum(task.r - supply, 0.0)
                    gamma = float(np.exp(-np.linalg.norm(deficit)))
                    # 协作质量项 Omega, 公式 (10)
                    omega_dist = self._dist_quality(agents, cand, task.l)
                    omega_link = self._link_quality(agents, cand)
                    omega_hist = self._history_quality(agents, cand)
                    omega = (self.omega[0] * omega_dist +
                             self.omega[1] * omega_link +
                             self.omega[2] * omega_hist)
                    w = task.pi * gamma * omega  # 公式 (8)
                    edges.append(Hyperedge(nodes=cand, w=w, type='tsk'))
        return edges

    @staticmethod
    def _dist_quality(agents, cand, loc) -> float:
        ds = [np.linalg.norm(agents[i].s[:len(loc)] - loc) for i in cand]
        return float(np.exp(-np.mean(ds) / 100.0))

    @staticmethod
    def _link_quality(agents, cand) -> float:
        return 0.8  # 简化实现, 可替换为真实通信质量

    @staticmethod
    def _history_quality(agents, cand) -> float:
        return float(np.mean([np.mean(agents[i].a) for i in cand]))

    # ---- 通信超边 ----
    def build_com_edges(self, P_rel: np.ndarray, groups: List[List[int]]) -> List[Hyperedge]:
        """生成通信型超边, 见公式 (11)-(12)"""
        edges = []
        for grp in groups:
            if len(grp) < 2:
                continue
            pairs = [(i, j) for i in grp for j in grp if i < j]
            ps = [P_rel[i, j] for i, j in pairs]
            if min(ps) >= self.theta_rel:
                # 几何均值, 公式 (12)
                w = float(np.exp(np.mean(np.log(np.array(ps) + 1e-12))))
                edges.append(Hyperedge(nodes=grp, w=w, type='com'))
        return edges

    # ---- 资源竞争超边 ----
    def build_res_edges(self, agents: List[Agent], groups: List[List[int]],
                        R_cap: Dict[str, float],
                        res_types: List[str]) -> List[Hyperedge]:
        """生成资源竞争型超边, 见公式 (13)-(14)"""
        edges = []
        for grp in groups:
            for nu_idx, nu in enumerate(res_types):
                total = sum(agents[i].d_res[nu_idx] for i in grp)
                cap = R_cap[nu]
                if total > cap:
                    w = -self.kappa_res * (total - cap) / (cap + 1e-12)
                    edges.append(Hyperedge(nodes=grp, w=w, type='res', res_type=nu))
        return edges

    # ---- 空间冲突超边 ----
    def build_cfl_edges(self, P_cfl: Dict[Tuple[int, ...], float],
                        groups: List[List[int]]) -> List[Hyperedge]:
        """生成空间冲突型超边, 见公式 (15)-(16)"""
        edges = []
        for grp in groups:
            key = tuple(sorted(grp))
            p = P_cfl.get(key, 0.0)
            if p >= self.theta_cfl:
                w = -self.kappa_cfl * p
                edges.append(Hyperedge(nodes=grp, w=w, type='cfl'))
        return edges


# =====================================================================
# 异配超图嵌入 H-HGNN (Heterophilic Hypergraph Embedding)
# =====================================================================

class HHGNN:
    """异配感知超图卷积网络, 见公式 (29)-(30)"""

    def __init__(self, in_dim: int, hid_dim: int, num_layers: int = 2,
                 seed: int = 42):
        rng = np.random.default_rng(seed)
        self.num_layers = num_layers
        # 可学习参数 Theta^(l)
        dims = [in_dim] + [hid_dim] * num_layers
        self.Theta = [rng.normal(0, 0.1, size=(dims[l], dims[l + 1]))
                      for l in range(num_layers)]
        # 超边权重调制系数 Lambda^(l) 用全 1 初始化
        self.Lambda_scale = [1.0 for _ in range(num_layers)]

    @staticmethod
    def _relu(x): return np.maximum(x, 0.0)

    def forward(self, hg: Hypergraph, X: np.ndarray) -> np.ndarray:
        """前向传播, 见公式 (29)"""
        if hg.num_edges == 0:
            return X
        H = hg.incidence_matrix()
        W = np.abs(hg.weights())   # 嵌入采用绝对权重
        Dv, De = hg.degree_matrices()
        Dv_inv_sqrt = np.diag(1.0 / np.sqrt(np.diag(Dv) + 1e-12))
        De_inv = np.diag(1.0 / (np.diag(De) + 1e-12)) if De.size else np.zeros((0, 0))
        U = X
        for l in range(self.num_layers):
            Lam = np.diag(W * self.Lambda_scale[l])
            # 公式 (29) 的归一化卷积核
            P = Dv_inv_sqrt @ H @ Lam @ De_inv @ H.T @ Dv_inv_sqrt
            U = self._relu(P @ U @ self.Theta[l])
        return U


# =====================================================================
# DH-HCRC 主类 (Main Algorithm)
# =====================================================================

class DH_HCRC:
    """
    动态异配超图社区发现与资源协同算法 (Algorithm 1 & 2).
    """

    def __init__(self,
                 num_communities: int = 5,
                 res_types: Optional[List[str]] = None,
                 alpha: Optional[Dict[str, float]] = None,
                 mu: float = 0.5,
                 gamma: float = 0.4,             # 标签传播步长, 公式 (32)
                 delta: Tuple[float, float, float] = (1.0, 0.5, 0.5),  # 公式 (33)
                 R_max_iter: int = 20,           # 外层最大迭代次数
                 R_lp: int = 10,                 # 标签传播次数
                 R_loc: int = 5,                 # 局部精炼次数
                 K_hops: int = 2,                # 事件触发邻域跳数
                 R_max: int = 3,                 # 节点最多加入社区数
                 S_min: int = 1,
                 S_max: int = 50,
                 eta_feedback: float = 0.1,      # 资源反馈系数, 公式 (35)
                 tol_J: float = 1e-3,
                 seed: int = 42):
        self.L = num_communities
        self.res_types = res_types or ['com', 'cmp', 'eng', 'spc', 'air']
        # 目标函数权重 alpha_1..alpha_6, 公式 (23)
        default_alpha = {'phi': 0.25, 'tsk': 0.25, 'com': 0.15,
                         'res': 0.15, 'cfl': 0.10, 'psi': 0.10}
        self.alpha = alpha or default_alpha
        self.mu = mu
        self.gamma = gamma
        self.delta = delta
        self.R_max_iter = R_max_iter
        self.R_lp = R_lp
        self.R_loc = R_loc
        self.K_hops = K_hops
        self.R_max = R_max
        self.S_min, self.S_max = S_min, S_max
        self.eta_fb = eta_feedback
        self.tol_J = tol_J
        self.rng = np.random.default_rng(seed)

        self.Z_prev: Optional[np.ndarray] = None
        self.Y_prev: Optional[np.ndarray] = None

    # -----------------------------------------------------------------
    # 1) 容量互补度 Phi_l, 公式 (20)
    # -----------------------------------------------------------------
    def _phi(self, Z: np.ndarray, C_tilde: np.ndarray) -> float:
        d_c = C_tilde.shape[1]
        total = 0.0
        for l in range(Z.shape[1]):
            M = np.zeros((d_c, d_c))
            for i in range(Z.shape[0]):
                M += Z[i, l] * np.outer(C_tilde[i], C_tilde[i])
            sign, logdet = np.linalg.slogdet(np.eye(d_c) + M)
            if sign > 0:
                total += logdet
        return total

    # -----------------------------------------------------------------
    # 2) 超边贡献项 Q^{type}, 公式 (21)
    # -----------------------------------------------------------------
    def _Q(self, Z: np.ndarray, hg: Hypergraph, etype: str) -> float:
        s = 0.0
        for e in hg.E:
            if e.type != etype:
                continue
            for l in range(Z.shape[1]):
                s += abs(e.w) * chi_coverage(Z, e.nodes, l)
        return s

    # -----------------------------------------------------------------
    # 3) 社区目标 J_com, 公式 (23)
    # -----------------------------------------------------------------
    def _J_com(self, Z: np.ndarray, hg: Hypergraph, C_tilde: np.ndarray) -> float:
        phi = self._phi(Z, C_tilde)
        q_tsk = self._Q(Z, hg, 'tsk')
        q_com = self._Q(Z, hg, 'com')
        q_res = self._Q(Z, hg, 'res')
        q_cfl = self._Q(Z, hg, 'cfl')
        # 时间平滑项 Psi, 公式 (22)
        psi = 0.0
        if self.Z_prev is not None and self.Z_prev.shape == Z.shape:
            psi = float(np.linalg.norm(Z - self.Z_prev, 'fro') ** 2)
        a = self.alpha
        return (a['phi'] * phi + a['tsk'] * q_tsk + a['com'] * q_com
                - a['res'] * q_res - a['cfl'] * q_cfl - a['psi'] * psi)

    # -----------------------------------------------------------------
    # 4) 社区资源需求 D_l^nu, 公式 (24)
    # -----------------------------------------------------------------
    def _community_demand(self, Z: np.ndarray, agents: List[Agent],
                          hg: Hypergraph) -> np.ndarray:
        N, L = Z.shape
        num_res = len(self.res_types)
        D = np.zeros((L, num_res))
        for nu in range(num_res):
            d_vec = np.array([a.d_res[nu] for a in agents])
            D[:, nu] = Z.T @ d_vec
        # 协作开销项 Delta_e^nu 这里简化为 0.05*|e|
        for e in hg.E:
            for l in range(L):
                cov = chi_coverage(Z, e.nodes, l)
                D[l, :] += 0.05 * len(e.nodes) * cov
        return D

    # -----------------------------------------------------------------
    # 5) 资源子问题求解, 公式 (25)(26)(34)
    # -----------------------------------------------------------------
    def _solve_resource(self, D: np.ndarray, R_cap: Dict[str, float]) -> Tuple[np.ndarray, np.ndarray]:
        """返回 Y 与短缺量 delta_l^nu."""
        L, num_res = D.shape
        Y = np.zeros_like(D)
        shortage = np.zeros_like(D)
        for nu_idx, nu in enumerate(self.res_types):
            cap = R_cap.get(nu, 1.0)
            demand = D[:, nu_idx]
            total = demand.sum()
            if total <= cap:
                Y[:, nu_idx] = demand
            else:
                # 按需求比例分配, 不足部分计入短缺
                Y[:, nu_idx] = demand * (cap / (total + 1e-12))
                shortage[:, nu_idx] = np.maximum(demand - Y[:, nu_idx], 0.0)
        return Y, shortage

    def _J_res(self, Y: np.ndarray) -> float:
        """资源协调代价, 公式 (26), 简化为 phi^nu = y^2"""
        return float(np.sum(Y ** 2))

    # -----------------------------------------------------------------
    # 6) 异配标签传播, 公式 (32)(33)
    # -----------------------------------------------------------------
    def _label_propagation(self, Z: np.ndarray, hg: Hypergraph,
                           C_tilde: np.ndarray,
                           P_rel: np.ndarray, P_cfl_pair: np.ndarray,
                           omega_nodes: List[int]) -> np.ndarray:
        Z_new = Z.copy()
        for i in omega_nodes:
            agg = np.zeros(self.L)
            for e in hg.E:
                if i not in e.nodes:
                    continue
                others = [j for j in e.nodes if j != i]
                if not others:
                    continue
                # 异配传播系数 varphi_ij^e, 公式 (33)
                scores = []
                for j in others:
                    s = (self.delta[0] * (1 - float(C_tilde[i] @ C_tilde[j]))
                         + self.delta[1] * P_rel[i, j]
                         - self.delta[2] * P_cfl_pair[i, j])
                    scores.append(s)
                scores = np.array(scores)
                phi_ij = np.exp(scores - scores.max())
                phi_ij /= phi_ij.sum() + 1e-12
                contrib = np.zeros(self.L)
                for idx_j, j in enumerate(others):
                    contrib += phi_ij[idx_j] * Z[j]
                agg += (e.w / len(e.nodes)) * contrib
            Z_new[i] = (1 - self.gamma) * Z[i] + self.gamma * agg
        # 投影到可行集
        return project_membership(Z_new, self.R_max, self.S_min, self.S_max)

    # -----------------------------------------------------------------
    # 7) 贪心 warm-start, 公式 (31)
    # -----------------------------------------------------------------
    def _greedy_init(self, C_tilde: np.ndarray, phi_min: float = 1e-3) -> np.ndarray:
        N = C_tilde.shape[0]
        Z = np.zeros((N, self.L))
        for l in range(self.L):
            current_M = np.eye(C_tilde.shape[1])
            assigned = set()
            while len(assigned) < min(self.S_max, N):
                best_gain, best_i = -np.inf, -1
                base = np.linalg.slogdet(current_M)[1]
                for i in range(N):
                    if i in assigned:
                        continue
                    M_new = current_M + np.outer(C_tilde[i], C_tilde[i])
                    new_val = np.linalg.slogdet(M_new)[1]
                    gain = new_val - base
                    if gain > best_gain:
                        best_gain, best_i = gain, i
                if best_gain < phi_min or best_i < 0:
                    break
                Z[best_i, l] = 1.0
                current_M += np.outer(C_tilde[best_i], C_tilde[best_i])
                assigned.add(best_i)
        return project_membership(Z, self.R_max, self.S_min, self.S_max)

    # -----------------------------------------------------------------
    # 8) 局部质量上升精炼
    # -----------------------------------------------------------------
    def _local_refine(self, Z: np.ndarray, hg: Hypergraph, C_tilde: np.ndarray,
                      omega_nodes: List[int]) -> np.ndarray:
        base_J = self._J_com(Z, hg, C_tilde)
        for i in omega_nodes:
            best_J, best_Z = base_J, Z.copy()
            for l in range(self.L):
                for new_val in (0.0, 0.5, 1.0):
                    Z_try = Z.copy()
                    Z_try[i, l] = new_val
                    Z_try = project_membership(Z_try, self.R_max, self.S_min, self.S_max)
                    J_try = self._J_com(Z_try, hg, C_tilde)
                    if J_try > best_J:
                        best_J, best_Z = J_try, Z_try
            if best_J > base_J:
                Z, base_J = best_Z, best_J
        return Z

    # -----------------------------------------------------------------
    # 9) 资源反馈机制, 公式 (35)
    # -----------------------------------------------------------------
    def _resource_feedback(self, hg: Hypergraph, shortage: np.ndarray,
                           Z: np.ndarray) -> None:
        if shortage.sum() <= 0:
            return
        for e in hg.E:
            if e.type != 'res':
                continue
            # 找到主要覆盖该超边的社区
            for l in range(Z.shape[1]):
                cov = chi_coverage(Z, e.nodes, l)
                if cov > 0.3:
                    s_norm = float(np.linalg.norm(shortage[l]))
                    e.w -= self.eta_fb * s_norm
            # 限制权重范围
            e.w = float(np.clip(e.w, -10.0, -1e-3))

    # -----------------------------------------------------------------
    # 10) 事件触发: 定位受影响节点 (K-hop neighborhood)
    # -----------------------------------------------------------------
    def _affected_region(self, hg: Hypergraph, delta_edges: List[Hyperedge]) -> List[int]:
        if not delta_edges:
            return []
        seed_nodes = set()
        for e in delta_edges:
            seed_nodes.update(e.nodes)
        # 构造节点-超边邻接关系做 K 跳扩展
        node_edges = {i: [] for i in range(hg.N)}
        for e_idx, e in enumerate(hg.E):
            for v in e.nodes:
                node_edges[v].append(e_idx)
        frontier = set(seed_nodes)
        visited = set(seed_nodes)
        for _ in range(self.K_hops):
            new_front = set()
            for v in frontier:
                for e_idx in node_edges[v]:
                    for u in hg.E[e_idx].nodes:
                        if u not in visited:
                            visited.add(u)
                            new_front.add(u)
            frontier = new_front
        return sorted(visited)

    # -----------------------------------------------------------------
    # 11) 联合优化主循环 (Algorithm 2)
    # -----------------------------------------------------------------
    def joint_optimize(self, hg: Hypergraph, agents: List[Agent],
                       R_cap: Dict[str, float],
                       Z_init: np.ndarray,
                       omega_nodes: List[int],
                       P_rel: np.ndarray,
                       P_cfl_pair: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
        C_tilde = np.array([l2_normalize(a.c) for a in agents])
        Z = Z_init.copy()
        J_prev = self._J_com(Z, hg, C_tilde) - self.mu * self._J_res(
            self._solve_resource(self._community_demand(Z, agents, hg), R_cap)[0])

        for r in range(self.R_max_iter):
            # (a) 标签传播
            for _ in range(self.R_lp):
                Z = self._label_propagation(Z, hg, C_tilde, P_rel, P_cfl_pair, omega_nodes)
            # (b) 局部精炼
            for _ in range(self.R_loc):
                Z_new = self._local_refine(Z, hg, C_tilde, omega_nodes)
                if np.allclose(Z_new, Z):
                    break
                Z = Z_new
            # (c) 资源子问题
            D = self._community_demand(Z, agents, hg)
            Y, shortage = self._solve_resource(D, R_cap)
            # (d) 资源反馈, 公式 (35)
            if shortage.sum() > 0:
                self._resource_feedback(hg, shortage, Z)
            # (e) 总目标 J, 公式 (27)
            J_new = self._J_com(Z, hg, C_tilde) - self.mu * self._J_res(Y)
            if abs(J_new - J_prev) < self.tol_J:
                break
            J_prev = J_new
        return Z, Y

    # -----------------------------------------------------------------
    # 12) 主流程 (Algorithm 1)
    # -----------------------------------------------------------------
    def step(self,
             agents: List[Agent],
             hg: Hypergraph,
             R_cap: Dict[str, float],
             P_rel: np.ndarray,
             P_cfl_pair: np.ndarray,
             delta_edges: Optional[List[Hyperedge]] = None,
             trigger: bool = True) -> Tuple[np.ndarray, np.ndarray]:
        """单步求解 (对应一次时刻 t)."""
        N = len(agents)
        # 无事件触发: 沿用上一时刻结果
        if not trigger and self.Z_prev is not None:
            return self.Z_prev, self.Y_prev

        # 确定受影响节点 Omega(t)
        if delta_edges:
            omega = self._affected_region(hg, delta_edges)
        else:
            omega = list(range(N))

        # warm-start
        C_tilde = np.array([l2_normalize(a.c) for a in agents])
        if self.Z_prev is not None and self.Z_prev.shape == (N, self.L):
            Z_init = self.Z_prev.copy()
            # 受影响节点用贪心重置
            Z_greedy = self._greedy_init(C_tilde)
            for i in omega:
                Z_init[i] = Z_greedy[i]
        else:
            Z_init = self._greedy_init(C_tilde)

        Z_init = project_membership(Z_init, self.R_max, self.S_min, self.S_max)

        Z_star, Y_star = self.joint_optimize(
            hg, agents, R_cap, Z_init, omega, P_rel, P_cfl_pair)

        self.Z_prev, self.Y_prev = Z_star, Y_star
        return Z_star, Y_star


# =====================================================================
# 分布式 Gossip 实现 (Algorithm 3, 公式 (36))
# =====================================================================

def metropolis_weights(adj: np.ndarray) -> np.ndarray:
    """生成 Metropolis 权重矩阵 (双随机)."""
    N = adj.shape[0]
    deg = adj.sum(axis=1)
    A = np.zeros_like(adj, dtype=float)
    for i in range(N):
        for j in range(N):
            if i != j and adj[i, j] > 0:
                A[i, j] = 1.0 / (1.0 + max(deg[i], deg[j]))
        A[i, i] = 1.0 - A[i].sum()
    return A


def gossip_update(Z: np.ndarray, adj: np.ndarray, grad: np.ndarray,
                  epsilon: float = 0.1, R_dis: int = 20,
                  R_max: int = 3, S_min: int = 1, S_max: int = 50) -> np.ndarray:
    """分布式 Gossip 隶属更新, 见公式 (36)"""
    A = metropolis_weights(adj)
    Z_new = Z.copy()
    for _ in range(R_dis):
        consensus = A @ Z_new - Z_new
        Z_new = Z_new + epsilon * consensus + epsilon * grad
        Z_new = project_membership(Z_new, R_max, S_min, S_max)
    return Z_new


# =====================================================================
# 简单的运行示例 (Demo)
# =====================================================================

if __name__ == "__main__":
    rng = np.random.default_rng(0)
    N, K, d_c = 20, 4, 6
    num_res = 5
    res_types = ['com', 'cmp', 'eng', 'spc', 'air']

    # 构造智能体
    agents = [Agent(idx=i,
                    c=rng.uniform(0, 1, d_c),
                    s=rng.uniform(0, 100, 4),
                    a=rng.uniform(0.5, 1, 2),
                    d_res=rng.uniform(0.05, 0.2, num_res))
              for i in range(N)]

    # 构造任务
    tasks = [Task(idx=k,
                  r=rng.uniform(0.3, 1.0, d_c),
                  l=rng.uniform(0, 100, 2),
                  tau=(0.0, 10.0),
                  rho=rng.uniform(0.1, 0.5, num_res),
                  pi=rng.uniform(0.3, 1.0))
             for k in range(K)]

    # 任务-智能体贡献系数 eta
    eta = rng.uniform(0.2, 0.9, (N, K))

    # 候选子集 (随机抽样)
    candidates = [list(rng.choice(N, size=4, replace=False)) for _ in range(15)]

    # 通信可靠性、冲突概率
    P_rel = rng.uniform(0.6, 0.95, (N, N)); np.fill_diagonal(P_rel, 1.0)
    P_cfl_pair = rng.uniform(0.0, 0.3, (N, N)); np.fill_diagonal(P_cfl_pair, 0.0)

    # 资源容量
    R_cap = {nu: 4.0 for nu in res_types}

    # 构造超图
    builder = HypergraphBuilder()
    hg = Hypergraph(V=agents)
    hg.E.extend(builder.build_task_edges(agents, tasks, eta, candidates))
    hg.E.extend(builder.build_com_edges(P_rel, candidates))
    hg.E.extend(builder.build_res_edges(agents, candidates, R_cap, res_types))

    # 运行 DH-HCRC
    model = DH_HCRC(num_communities=3, res_types=res_types)
    Z, Y = model.step(agents, hg, R_cap, P_rel, P_cfl_pair)

    print("Membership matrix Z shape:", Z.shape)
    print("Resource allocation Y shape:", Y.shape)
    print("Sample Z (first 5 rows):\n", np.round(Z[:5], 3))
    print("Resource allocation Y:\n", np.round(Y, 3))
